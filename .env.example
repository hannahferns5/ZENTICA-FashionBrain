# Copy this file to `.env` and fill in your Hugging Face access token.
# Do NOT commit your real `.env` to git. Add it to .gitignore.

# Your Hugging Face token (from https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# Optional: local dataset directory (imagefolder format) to use instead of HF Hub
#LOCAL_DATA_DIR=/absolute/path/to/your/local/dataset
